# 🔌 Puerto del servidor
PORT=3000

# 🗄️ Conexión a PostgreSQL (usuario: postgres | contraseña: 1234 | bd: pos_db)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/pos_db

# 🔑 Claves JWT (strings aleatorios para firmar tokens)
JWT_SECRET=pos_access_key_2026_supersegura
JWT_REFRESH_SECRET=pos_refresh_key_2026_supersegura

# 🌍 Entorno de ejecución
NODE_ENV=development